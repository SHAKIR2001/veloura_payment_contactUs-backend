# Stripe keys (use test keys while developing)
# Set this in your local `.env` (do not commit secrets)
STRIPE_SECRET_KEY=
# Optional settings
PORT=5003
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost,http://127.0.0.1
# Stripe currency; use a supported currency for your Stripe account (commonly: usd)
STRIPE_CURRENCY=usd
